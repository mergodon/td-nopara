#!/usr/bin/env bash
# td-flow pre-commit hook — runs the project's Test command from .td/WORKWAY.md § Local testing.
# Installed by /td-init. Do not bypass with --no-verify.

set -e

if [ ! -f .td/WORKWAY.md ]; then
  echo "td-flow: .td/WORKWAY.md not found — skipping test check"
  exit 0
fi

CMD=$(awk '
  /^## Local testing/ { in_section = 1; next }
  /^## / && in_section { exit }
  in_section && /^- Test command:/ {
    sub(/^- Test command:[[:space:]]*/, "")
    print
    exit
  }
' .td/WORKWAY.md | xargs)

if [ -z "$CMD" ] || [ "$CMD" = "none" ] || [ "$CMD" = "{{test_command}}" ]; then
  echo "td-flow: no runnable Test command in .td/WORKWAY.md § Local testing — skipping"
  exit 0
fi

echo "td-flow: running pre-commit test → $CMD"
eval "$CMD"
