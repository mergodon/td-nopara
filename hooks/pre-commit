#!/usr/bin/env bash
# td-flow pre-commit hook — runs the project's test command from .td/TESTING.md.
# Installed by /td-init. Bypass it only via /td-reset (which checkpoints first), never with --no-verify.

set -e

if [ ! -f .td/TESTING.md ]; then
  echo "td-flow: .td/TESTING.md not found — skipping test check"
  exit 0
fi

# Extract the first fenced code block under "## Test command"
CMD=$(awk '
  /^## Test command/ { in_section = 1; next }
  in_section && /^```/ { if (capturing) exit; capturing = 1; next }
  capturing { print; exit }
' .td/TESTING.md | head -1 | xargs)

if [ -z "$CMD" ]; then
  echo "td-flow: no Test command in .td/TESTING.md — skipping"
  exit 0
fi

if [[ "$CMD" == *"no tests"* ]] || [[ "$CMD" == "{{test_command}}" ]]; then
  echo "td-flow: Test command is a placeholder — skipping. Update .td/TESTING.md."
  exit 0
fi

echo "td-flow: running pre-commit test → $CMD"
eval "$CMD"
