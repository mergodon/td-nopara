#!/usr/bin/env bash
# td-flow pre-commit hook — runs the project's Test command from <td-dir>/WORKWAY.md § Local testing.
# Installed by /td-flow-init. Don't skip it with --no-verify on code commits.
#
# Path resolution: prefers .td-flow/ (v7.0 canonical) and falls back to .td/
# (pre-v7.0 layout). The fallback is a transition safety net — projects that
# pulled v7.0 framework but haven't run /td-flow-refresh yet still work.
# Drop the fallback in a future v8.0 once all projects have migrated.

set -e

if [ -f .td-flow/WORKWAY.md ]; then
  WORKWAY=.td-flow/WORKWAY.md
elif [ -f .td/WORKWAY.md ]; then
  WORKWAY=.td/WORKWAY.md
else
  echo "td-flow: no WORKWAY.md found in .td-flow/ or .td/ — skipping test check"
  exit 0
fi

CMD=$(awk '
  /^## Local testing/ { in_section = 1; next }
  /^## / && in_section { exit }
  in_section && /^- Test command:/ {
    sub(/^- Test command:[[:space:]]*/, "")
    print
    exit
  }
' "$WORKWAY" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')

if [ -z "$CMD" ] || [ "$CMD" = "none" ] || [ "$CMD" = "{{test_command}}" ]; then
  echo "td-flow: no runnable Test command in $WORKWAY § Local testing — skipping"
  exit 0
fi

echo "td-flow: running pre-commit test → $CMD"
eval "$CMD"
